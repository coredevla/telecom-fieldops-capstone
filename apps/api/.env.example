NODE_ENV=development
PORT=3000

# Legacy/shared secret (compatibility)
JWT_SECRET=change-this-legacy-secret

# Preferred token secrets
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret

JWT_ISSUER=telecom-fieldops-api
JWT_AUDIENCE=telecom-fieldops-clients

BCRYPT_ROUNDS=10

# CORS: set in production so the frontend can call the API (e.g. Railway + Vercel).
# FRONTEND_URL=https://your-app.vercel.app
# API_PUBLIC_URL=https://your-api.up.railway.app

# Database: única conexión. Base "capstone". En primer deploy (Railway): "npm run migrate" y "npm run seed".
#
# Opción A — Transaction pooler (puerto 6543): ideal para app en producción (menos conexiones).
# Incluir pgbouncer=true y uselibpqcompat=true.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/capstone?pgbouncer=true&sslmode=require&uselibpqcompat=true
#
# Opción B — Conexión directa (puerto 5432): NO usar pgbouncer=true. Sí uselibpqcompat=true para evitar error de certificado SSL.
# DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/capstone?sslmode=require&uselibpqcompat=true
#
# Opcional: solo para `prisma migrate dev` (shadow DB). La app y migrate deploy usan solo DATABASE_URL.
# SHADOW_DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/store?sslmode=require
