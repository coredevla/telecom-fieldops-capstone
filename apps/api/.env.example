NODE_ENV=development
PORT=3000

FRONTEND_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:3000

JWT_ACCESS_SECRET=replace-with-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
JWT_ISSUER=telecom-fieldops-api
JWT_AUDIENCE=telecom-fieldops-clients
BCRYPT_ROUNDS=10

OAUTH_AUTH0_DOMAIN=your-tenant.us.auth0.com
OAUTH_AUTH0_CLIENT_ID=your-auth0-client-id
OAUTH_AUTH0_CLIENT_SECRET=your-auth0-client-secret
OAUTH_AUTH0_AUDIENCE=
OAUTH_AUTH0_SCOPE=openid profile email
OAUTH_AUTH0_PASSWORD_GRANT_ENABLED=false
OAUTH_AUTH0_CONNECTION=
